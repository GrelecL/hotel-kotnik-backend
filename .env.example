# Copy to .env and fill in values
# Generate DB_PASSWORD and FERNET_KEY with: python scripts/generate_keys.py

# Database password
DB_PASSWORD=

# Fernet key for IMAP password encryption (base64, 32 bytes)
FERNET_KEY=

# OpenRouter API key
OPENROUTER_API_KEY=

# Optional: override LLM model
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Tailscale IP of this VM - API binds only here
# Leave as 0.0.0.0 only if firewall rules protect the port on other interfaces
TAILSCALE_IP=100.x.x.x

# Email poll interval in seconds (default 45)
EMAIL_POLL_INTERVAL=45
